{
  "name": "@trinaryex/keyspace",
  "version": "2.0.0",
  "description": "SDK for Triex ACL encrypted data sharing on Sui + Seal",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:cov": "node --experimental-vm-modules node_modules/.bin/jest --ci --coverage",
    "prettier": "prettier --write '{src,test}/**/*.ts'",
    "prettier:check": "prettier --check '{src,test}/**/*.ts'",
    "lint": "eslint --cache '{src,test}/**/*.ts'",
    "lint:check": "eslint --cache '{src,test}/**/*.ts'",
    "lint:fix": "eslint --cache --fix '{src,test}/**/*.ts'",
    "tscheck": "tsc --noEmit",
    "release": "semantic-release"
  },
  "author": "@blurpesec",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@mysten/seal": "^1.1.1",
    "@mysten/sui": "^2.16.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "@mysten/seal": "^1.1.1",
    "@mysten/sui": "^2.16.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/github": "^10.0.0",
    "@semantic-release/npm": "^12.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@types/jest": "^29.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "semantic-release": "^24.0.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "moduleFileExtensions": [
      "js",
      "mjs",
      "json",
      "ts"
    ],
    "testRegex": ".test.ts$",
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true,
          "diagnostics": false
        }
      ]
    },
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,js}",
      "!**/*Module.ts"
    ],
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "statements": 80,
        "branches": 70,
        "functions": 80,
        "lines": 80
      }
    },
    "coverageDirectory": "./coverage"
  }
}
